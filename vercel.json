{
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/service-1/?$",
      "status": 308,
      "headers": {
        "Location": "/services"
      }
    },
    {
      "src": "/service-1\\.html$",
      "status": 308,
      "headers": {
        "Location": "/services"
      }
    },
    {
      "src": "/service-3/?$",
      "status": 308,
      "headers": {
        "Location": "/services"
      }
    },
    {
      "src": "/service-3\\.html$",
      "status": 308,
      "headers": {
        "Location": "/services"
      }
    },
    {
      "src": "/services/?$",
      "dest": "/service-3.html"
    },
    {
      "src": "/blog/([^/]+)/?$",
      "dest": "/blog-details.html?slug=$1"
    },
    {
      "src": "/(.+)/",
      "dest": "/$1.html"
    },
    {
      "src": "/(.+)",
      "dest": "/$1.html"
    }
  ]
}
